X <- as.matrix(iris[, 1:3])
Z <- model.matrix(X ~ ., data = iris[, 4:5])[, -1]
mod <- nmfqp.reg(X, Z, 2)
expect_equal(nrow(mod$W), nrow(iris))
expect_equal(ncol(mod$W), 2)
expect_equal(nrow(mod$H), 2)
expect_equal(ncol(mod$H), 3)
expect_equal(dim(mod$B), c(ncol(Z), 3))
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
})
test_that("nmfqp.reg handles different k values", {
set.seed(777)
X <- matrix(abs(rnorm(80 * 12)), nrow = 80, ncol = 12)
Z <- matrix(rnorm(80 * 3), nrow = 80, ncol = 3)
# Small k
mod1 <- nmfqp.reg(X, Z, k = 1)
expect_equal(ncol(mod1$W), 1)
expect_equal(nrow(mod1$H), 1)
# Medium k
mod2 <- nmfqp.reg(X, Z, k = 5)
expect_equal(ncol(mod2$W), 5)
expect_equal(nrow(mod2$H), 5)
# Larger k (but still < d)
mod3 <- nmfqp.reg(X, Z, k = 10)
expect_equal(ncol(mod3$W), 10)
expect_equal(nrow(mod3$H), 10)
})
test_that("nmfqp.reg with single covariate works", {
set.seed(888)
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
Z <- matrix(rnorm(60 * 1), nrow = 60, ncol = 1)
mod <- nmfqp.reg(X, Z, k = 3)
expect_equal(nrow(mod$B), 1)
expect_equal(ncol(mod$B), ncol(X))
expect_true(!is.null(mod$W))
expect_true(!is.null(mod$H))
})
test_that("nmfqp.reg with many covariates works", {
set.seed(999)
n <- 100
d <- 12
q <- 15  # Many covariates
k <- 3
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
Z <- matrix(rnorm(n * q), nrow = n, ncol = q)
mod <- nmfqp.reg(X, Z, k)
expect_equal(dim(mod$B), c(q, d))
expect_true(all(is.finite(mod$B)))
expect_true(all(is.finite(mod$W)))
expect_true(all(is.finite(mod$H)))
})
test_that("nmfqp.reg objective decreases or stays constant", {
set.seed(1111)
X <- matrix(abs(rnorm(70 * 9)), nrow = 70, ncol = 9)
Z <- matrix(rnorm(70 * 3), nrow = 70, ncol = 3)
# Run with different maxiter to check convergence behavior
mod_short <- nmfqp.reg(X, Z, k = 3, maxiter = 10)
mod_long <- nmfqp.reg(X, Z, k = 3, maxiter = 100)
# Longer run should have equal or better objective
expect_true(mod_long$obj <= mod_short$obj * 1.01)  # Allow 1% tolerance
})
test_that("nmfqp.reg handles standardized vs raw covariates", {
set.seed(1212)
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
Z_raw <- matrix(rnorm(60 * 3, mean = 100, sd = 50), nrow = 60, ncol = 3)
Z_std <- scale(Z_raw)
mod_raw <- nmfqp.reg(X, Z_raw, k = 2)
mod_std <- nmfqp.reg(X, Z_std, k = 2)
# Both should converge
expect_true(!is.null(mod_raw))
expect_true(!is.null(mod_std))
expect_true(all(is.finite(mod_raw$B)))
expect_true(all(is.finite(mod_std$B)))
})
test_that("nmfqp.reg with intercept in Z works", {
set.seed(1313)
X <- matrix(abs(rnorm(60 * 6)), nrow = 60, ncol = 6)
# Include intercept explicitly
Z_with_intercept <- cbind(1, matrix(rnorm(60 * 2), nrow = 60, ncol = 2))
mod <- nmfqp.reg(X, Z_with_intercept, k = 2)
expect_equal(nrow(mod$B), 3)  # Intercept + 2 covariates
expect_true(!is.null(mod))
})
test_that("nmfqp.reg fitted values are close to X when model is good", {
set.seed(1414)
n <- 100
d <- 8
q <- 3
k <- 5
# Generate data from the model
B_true <- matrix(rnorm(q * d), q, d)
W_true <- matrix(abs(rnorm(n * k)), n, k)
H_true <- matrix(abs(rnorm(k * d)), k, d)
Z <- matrix(rnorm(n * q), n, q)
X <- Z %*% B_true + W_true %*% H_true + matrix(rnorm(n * d, sd = 0.1), n, d)
X[X < 0] <- 0  # Ensure non-negative
mod <- nmfqp.reg(X, Z, k)
# Reconstruction should be good
relative_error <- sqrt(mod$obj / sum(X^2))
expect_true(relative_error < 0.3)  # Relative error less than 30%
})
