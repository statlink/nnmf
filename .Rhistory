library(testthat)
library(nnmf)
test_that("nmf.qp returns correct structure", {
# Setup
set.seed(123)
n <- 100
d <- 8
k <- 3
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
# Fit model
mod <- nmf.qp(X, k)
# Check structure
expect_true(is.list(mod))
expect_named(mod, c("W", "H", "Z", "obj", "iters", "runtime"))
# Check dimensions
expect_equal(dim(mod$W), c(n, k))
expect_equal(dim(mod$H), c(k, d))
expect_equal(dim(mod$Z), c(n, d))
# Check scalar values
expect_true(is.numeric(mod$obj))
expect_length(mod$obj, 1)
expect_true(is.numeric(mod$iters))
expect_length(mod$iters, 1)
expect_true(is.numeric(mod$runtime))
expect_true(all(mod$runtime >= 0))
})
test_that("nmf.qp produces non-negative W and H", {
set.seed(456)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
mod <- nmf.qp(X, k = 3)
# W, H, and Z should be non-negative (NMF constraint)
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
expect_true(all(mod$Z >= 0))
})
test_that("nmf.qp reconstruction follows Z = W*H", {
set.seed(789)
n <- 80
d <- 10
k <- 4
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
mod <- nmf.qp(X, k)
# Check reconstruction
Z_reconstructed <- mod$W %*% mod$H
# Should be numerically identical (within tolerance)
expect_equal(mod$Z, Z_reconstructed, tolerance = 1e-10)
})
test_that("nmf.qp objective is sum of squared residuals", {
set.seed(111)
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
mod <- nmf.qp(X, k = 2)
# Calculate Frobenius norm squared manually
residuals <- X - mod$Z
frobenius_sq <- sum(residuals^2)
# Should match reported objective
expect_equal(mod$obj, frobenius_sq, tolerance = 1e-8)
})
test_that("nmf.qp with H_init converges", {
set.seed(222)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
k <- 3
# Create initial H
H_init <- matrix(abs(rnorm(k * 6)), nrow = k, ncol = 6)
mod <- nmf.qp(X, k, H_init = H_init)
expect_true(!is.null(mod))
expect_equal(dim(mod$H), dim(H_init))
expect_true(mod$iters <= 1000)  # Should converge
})
test_that("nmf.qp without H_init (NULL) works", {
set.seed(333)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
mod <- nmf.qp(X, k = 3, H_init = NULL)
expect_true(!is.null(mod))
expect_equal(ncol(mod$H), ncol(X))
expect_equal(nrow(mod$H), 3)
})
test_that("nmf.qp with k_means initialization works", {
set.seed(444)
X <- matrix(abs(rnorm(80 * 10)), nrow = 80, ncol = 10)
# K-means initialization
mod_kmeans <- nmf.qp(X, k = 4, k_means = TRUE)
# Random initialization
mod_random <- nmf.qp(X, k = 4, k_means = FALSE)
# Both should succeed
expect_true(!is.null(mod_kmeans))
expect_true(!is.null(mod_random))
# Results will differ due to initialization
expect_false(identical(mod_kmeans$W, mod_random$W))
})
test_that("nmf.qp with mini-batch k_means works", {
set.seed(555)
# Larger dataset for mini-batch
X <- matrix(abs(rnorm(200 * 12)), nrow = 200, ncol = 12)
# Standard k-means
mod_full <- nmf.qp(X, k = 3, k_means = TRUE, bs = 1)
# Mini-batch k-means
mod_batch <- nmf.qp(X, k = 3, k_means = TRUE, bs = 5)
# Both should succeed
expect_true(!is.null(mod_full))
expect_true(!is.null(mod_batch))
expect_equal(dim(mod_batch$W), c(200, 3))
})
test_that("nmf.qp respects maxiter parameter", {
set.seed(666)
X <- matrix(abs(rnorm(80 * 10)), nrow = 80, ncol = 10)
# Very small maxiter
mod1 <- nmf.qp(X, k = 4, maxiter = 5)
expect_true(mod1$iters <= 5)
# Larger maxiter
mod2 <- nmf.qp(X, k = 4, maxiter = 100)
expect_true(mod2$iters <= 100)
})
test_that("nmf.qp with different tolerance values", {
set.seed(777)
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
# Tight tolerance
mod_tight <- nmf.qp(X, k = 2, tol = 1e-8)
# Loose tolerance
mod_loose <- nmf.qp(X, k = 2, tol = 1e-4)
# Both should converge
expect_true(!is.null(mod_tight))
expect_true(!is.null(mod_loose))
# Tight tolerance should give lower or similar objective
expect_true(mod_tight$obj <= mod_loose$obj * 1.1)
})
test_that("nmf.qp with different ridge values", {
set.seed(888)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
# Different ridge values
mod1 <- nmf.qp(X, k = 3, ridge = 1e-8)
mod2 <- nmf.qp(X, k = 3, ridge = 1e-6)
mod3 <- nmf.qp(X, k = 3, ridge = 1e-4)
# All should succeed
expect_true(!is.null(mod1))
expect_true(!is.null(mod2))
expect_true(!is.null(mod3))
# Results should differ slightly
expect_false(identical(mod1$W, mod2$W))
})
test_that("nmf.qp parallel vs serial gives similar results", {
skip_if(parallel::detectCores() < 2, "Need at least 2 cores for parallel test")
set.seed(999)
X <- matrix(abs(rnorm(100 * 10)), nrow = 100, ncol = 10)
k <- 3
# Use same H_init for both to ensure identical starting point
H_init <- matrix(abs(rnorm(k * 10)), nrow = k, ncol = 10)
# Serial
mod_serial <- nmf.qp(X, k, H_init = H_init, ncores = 1)
# Parallel
mod_parallel <- nmf.qp(X, k, H_init = H_init, ncores = 2)
# Results should be very similar (numerical differences possible)
expect_equal(mod_serial$W, mod_parallel$W, tolerance = 1e-6)
expect_equal(mod_serial$H, mod_parallel$H, tolerance = 1e-6)
expect_equal(mod_serial$obj, mod_parallel$obj, tolerance = 1e-6)
})
test_that("nmf.qp iris example from documentation works", {
# This is the exact example from the documentation
X <- as.matrix(iris[, 1:4])
mod <- nmf.qp(X, 2)
expect_equal(nrow(mod$W), nrow(iris))
expect_equal(ncol(mod$W), 2)
expect_equal(nrow(mod$H), 2)
expect_equal(ncol(mod$H), 4)
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
# Verify we can use it for visualization (as in example)
group <- as.numeric(iris[, 5])
expect_equal(length(group), nrow(mod$W))
})
test_that("nmf.qp handles different k values", {
set.seed(1010)
X <- matrix(abs(rnorm(80 * 12)), nrow = 80, ncol = 12)
# k = 1 (minimum)
mod1 <- nmf.qp(X, k = 1)
expect_equal(ncol(mod1$W), 1)
expect_equal(nrow(mod1$H), 1)
# Medium k
mod2 <- nmf.qp(X, k = 5)
expect_equal(ncol(mod2$W), 5)
expect_equal(nrow(mod2$H), 5)
# Larger k (but still < d)
mod3 <- nmf.qp(X, k = 10)
expect_equal(ncol(mod3$W), 10)
expect_equal(nrow(mod3$H), 10)
})
test_that("nmf.qp handles wide matrices (n < d)", {
set.seed(1111)
n <- 50
d <- 100  # More variables than samples
k <- 10
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
# This should trigger hybrid algorithm (QP for W, EGD for H)
mod <- nmf.qp(X, k)
expect_equal(dim(mod$W), c(n, k))
expect_equal(dim(mod$H), c(k, d))
expect_true(all(is.finite(mod$W)))
expect_true(all(is.finite(mod$H)))
})
test_that("nmf.qp with lr_h parameter for wide matrices", {
set.seed(1212)
n <- 40
d <- 80  # Wide matrix
k <- 5
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
# Different learning rates for H update
mod1 <- nmf.qp(X, k, lr_h = 0.05)
mod2 <- nmf.qp(X, k, lr_h = 0.1)
mod3 <- nmf.qp(X, k, lr_h = 0.2)
# All should succeed
expect_true(!is.null(mod1))
expect_true(!is.null(mod2))
expect_true(!is.null(mod3))
})
test_that("nmf.qp objective decreases or stays constant", {
set.seed(1313)
X <- matrix(abs(rnorm(70 * 9)), nrow = 70, ncol = 9)
# Run with different maxiter
mod_short <- nmf.qp(X, k = 3, maxiter = 10)
mod_long <- nmf.qp(X, k = 3, maxiter = 100)
# Longer run should have equal or better objective
expect_true(mod_long$obj <= mod_short$obj * 1.01)
})
test_that("nmf.qp handles square matrices", {
set.seed(1414)
n <- 50
d <- 50  # Square matrix
k <- 10
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
mod <- nmf.qp(X, k)
expect_equal(dim(mod$W), c(n, k))
expect_equal(dim(mod$H), c(k, d))
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
})
test_that("nmf.qp handles tall matrices (n > d)", {
set.seed(1515)
n <- 200
d <- 10  # More samples than variables
k <- 5
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
mod <- nmf.qp(X, k)
expect_equal(dim(mod$W), c(n, k))
expect_equal(dim(mod$H), c(k, d))
expect_true(all(is.finite(mod$W)))
expect_true(all(is.finite(mod$H)))
})
test_that("nmf.qp reconstruction quality improves with k", {
set.seed(1616)
X <- matrix(abs(rnorm(80 * 12)), nrow = 80, ncol = 12)
# Small k
mod_k2 <- nmf.qp(X, k = 2, maxiter = 100)
# Medium k
mod_k5 <- nmf.qp(X, k = 5, maxiter = 100)
# Larger k
mod_k8 <- nmf.qp(X, k = 8, maxiter = 100)
# Generally, larger k should give better reconstruction (lower objective)
# (not always monotonic due to local minima, but should trend downward)
expect_true(mod_k8$obj <= mod_k2$obj)
})
test_that("nmf.qp handles data with varying scales", {
set.seed(1717)
n <- 60
d <- 8
# Data with different scales
X1 <- matrix(abs(rnorm(n * (d/2), mean = 1, sd = 0.1)), n, d/2)
X2 <- matrix(abs(rnorm(n * (d/2), mean = 100, sd = 10)), n, d/2)
X <- cbind(X1, X2)
mod <- nmf.qp(X, k = 3)
expect_true(!is.null(mod))
expect_true(all(is.finite(mod$W)))
expect_true(all(is.finite(mod$H)))
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
})
test_that("nmf.qp handles sparse-like data (many zeros)", {
set.seed(1818)
X <- matrix(abs(rnorm(80 * 10)), nrow = 80, ncol = 10)
# Make data sparse-like (set many values to zero)
X[X < quantile(X, 0.6)] <- 0
mod <- nmf.qp(X, k = 4)
expect_true(!is.null(mod))
expect_equal(dim(mod$W), c(80, 4))
expect_equal(dim(mod$H), c(4, 10))
})
test_that("nmf.qp with same seed gives reproducible results", {
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
k <- 3
# Same H_init for reproducibility
set.seed(1919)
H_init <- matrix(abs(rnorm(k * 8)), nrow = k, ncol = 8)
mod1 <- nmf.qp(X, k, H_init = H_init)
mod2 <- nmf.qp(X, k, H_init = H_init)
# Should get identical results with same initialization
expect_equal(mod1$W, mod2$W)
expect_equal(mod1$H, mod2$H)
expect_equal(mod1$obj, mod2$obj)
})
test_that("nmf.qp all outputs are finite", {
set.seed(2020)
X <- matrix(abs(rnorm(70 * 9)), nrow = 70, ncol = 9)
mod <- nmf.qp(X, k = 4)
# Check all outputs are finite (no NaN, Inf, -Inf)
expect_true(all(is.finite(mod$W)))
expect_true(all(is.finite(mod$H)))
expect_true(all(is.finite(mod$Z)))
expect_true(is.finite(mod$obj))
expect_true(is.finite(mod$iters))
})
