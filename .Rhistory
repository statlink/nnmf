library(nnmf)
test_that("nmf.qp returns correct structure", {
# Setup
set.seed(123)
n <- 100
d <- 8
k <- 3
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
# Fit model
mod <- nmf.qp(X, k)
# Check structure
expect_true(is.list(mod))
expect_named(mod, c("W", "H", "Z", "obj", "iters", "runtime"))
# Check dimensions
expect_equal(dim(mod$W), c(n, k))
expect_equal(dim(mod$H), c(k, d))
expect_equal(dim(mod$Z), c(n, d))
# Check scalar values
expect_true(is.numeric(mod$obj))
expect_length(mod$obj, 1)
expect_true(is.numeric(mod$iters))
expect_length(mod$iters, 1)
expect_true(is.numeric(mod$runtime))
expect_true(all(mod$runtime >= 0))
})
test_that("nmf.qp produces non-negative W and H", {
set.seed(456)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
mod <- nmf.qp(X, k = 3)
# W, H, and Z should be non-negative (NMF constraint)
expect_true(all(mod$W >= 0))
expect_true(all(mod$H >= 0))
expect_true(all(mod$Z >= 0))
})
test_that("nmf.qp reconstruction follows Z = W*H", {
set.seed(789)
n <- 80
d <- 10
k <- 4
X <- matrix(abs(rnorm(n * d)), nrow = n, ncol = d)
mod <- nmf.qp(X, k)
# Check reconstruction
Z_reconstructed <- mod$W %*% mod$H
# Should be numerically identical (within tolerance)
expect_equal(mod$Z, Z_reconstructed, tolerance = 1e-10)
})
test_that("nmf.qp objective is sum of squared residuals", {
set.seed(111)
X <- matrix(abs(rnorm(60 * 8)), nrow = 60, ncol = 8)
mod <- nmf.qp(X, k = 2)
# Calculate Frobenius norm squared manually
residuals <- X - mod$Z
frobenius_sq <- sum(residuals^2)
# Should match reported objective
expect_equal(mod$obj, frobenius_sq, tolerance = 1e-8)
})
test_that("nmf.qp with H_init converges", {
set.seed(222)
X <- matrix(abs(rnorm(50 * 6)), nrow = 50, ncol = 6)
k <- 3
# Create initial H
H_init <- matrix(abs(rnorm(k * 6)), nrow = k, ncol = 6)
mod <- nmf.qp(X, k, H_init = H_init)
expect_true(!is.null(mod))
expect_equal(dim(mod$H), dim(H_init))
expect_true(mod$iters <= 1000)  # Should converge
})
